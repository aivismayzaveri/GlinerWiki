# =============================================================================
# OpenKB Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Model (skips model prompt during openkb init if set)
# -----------------------------------------------------------------------------

# Default model in LiteLLM format (e.g. "openai/gpt-4.1-mini", "anthropic/claude-sonnet-4-6")
# If set, openkb init uses this without prompting. If unset, init prompts interactively.
LLM_MODEL=

# -----------------------------------------------------------------------------
# LLM API Keys (set one — LLM_API_KEY is the universal fallback)
# -----------------------------------------------------------------------------

# Universal key: if set, propagated to all provider-specific vars below
LLM_API_KEY=

# Provider-specific keys (override LLM_API_KEY if set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Custom Base URLs / Endpoints
# LiteLLM reads these automatically — use for proxies, self-hosted, or regional endpoints
# -----------------------------------------------------------------------------

# OpenAI-compatible endpoints (Azure, proxies, local servers)
# OPENAI_API_BASE=https://your-proxy.example.com/v1

# Anthropic-compatible endpoints (proxies, regional)
# ANTHROPIC_API_BASE=https://your-proxy.example.com

# -----------------------------------------------------------------------------
# Entity Extraction LLM (independent provider — optional)
# Model fallback: ENTITY_LLM_MODEL → entity_llm_model in config.yaml → main model
# Use a cheap/fast model on a separate endpoint for entity review
# -----------------------------------------------------------------------------

# Model name in LiteLLM format (e.g. "openai/gpt-4.1-nano", "anthropic/claude-haiku-4-5")
# Leave empty to use the main model from config.yaml (default behavior)
ENTITY_LLM_MODEL=

# Custom base URL for the entity LLM provider (independent of main provider)
# Only needed if ENTITY_LLM_MODEL points to a different provider than the main model
# e.g. "https://api.openai.com/v1" when main model uses Anthropic
ENTITY_LLM_BASE_URL=

# -----------------------------------------------------------------------------
# PageIndex (long document indexing)
# -----------------------------------------------------------------------------

# Optional: PageIndex Cloud API key for OCR + faster indexing of large PDFs
# Leave empty to use the open-source local version
PAGEINDEX_API_KEY=

# -----------------------------------------------------------------------------
# LiteLLM Configuration
# -----------------------------------------------------------------------------

# Use local model cost map instead of fetching from GitHub (faster startup)
LITELLM_LOCAL_MODEL_COST_MAP=True

# Suppress LiteLLM debug/info output (set in code, listed here for reference)
# LITELLM_LOG=ERROR

# -----------------------------------------------------------------------------
# Display / UI
# -----------------------------------------------------------------------------

# Disable colored output (useful for piping, CI, non-TTY)
# NO_COLOR=1

# -----------------------------------------------------------------------------
# OpenKB Paths
# -----------------------------------------------------------------------------

# Override auto-detected knowledge base directory
# OPENKB_DIR=/path/to/your/kb
